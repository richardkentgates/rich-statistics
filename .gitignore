# .gitignore — Rich Statistics

# -------------------------------------------------------------------------
# WordPress / Build artefacts
# -------------------------------------------------------------------------
/build/
*.zip

# -------------------------------------------------------------------------
# Freemius SDK — downloaded at build time by build.sh
# NOT committed to version control
# Run: bash build.sh   to download it before building the plugin ZIP
# -------------------------------------------------------------------------
/freemius/

# -------------------------------------------------------------------------
# PHP dev dependencies (Composer)
# -------------------------------------------------------------------------
/vendor/
!/vendor/chart.min.js

# -------------------------------------------------------------------------
# PHP test artefacts
# -------------------------------------------------------------------------
/phpunit.xml
/.phpunit.result.cache
/tests/_output/
/tests/tmp/
/wordpress-tests-lib/
/tmp/

# -------------------------------------------------------------------------
# OS / editor files
# -------------------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

# -------------------------------------------------------------------------
# Node (if ever added)
# -------------------------------------------------------------------------
node_modules/
npm-debug.log
yarn-error.log

# -------------------------------------------------------------------------
# Env / secrets
# -------------------------------------------------------------------------
.env
.env.local
wp-tests-config.php
