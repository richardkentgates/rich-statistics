{
  "name": "richardkentgates/rich-statistics",
  "description": "Privacy-first analytics for WordPress publishers.",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "Richard Kent Gates",
      "email": "mail@richardkentgates.com",
      "homepage": "https://statistics.richardkentgates.com"
    }
  ],
  "require": {
    "php": ">=8.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6 || ^10.5",
    "yoast/phpunit-polyfills": "^2.0",
    "brain/monkey": "^2.6",
    "mockery/mockery": "^1.6"
  },
  "autoload-dev": {
    "psr-4": {
      "RichStatistics\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --configuration phpunit.xml.dist --no-coverage",
    "test-coverage": "phpunit --configuration phpunit.xml.dist --coverage-html build/coverage",
    "phpcs": "phpcs --standard=WordPress --extensions=php --ignore=vendor,freemius,node_modules .",
    "phpcbf": "phpcbf --standard=WordPress --extensions=php --ignore=vendor,freemius,node_modules ."
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
